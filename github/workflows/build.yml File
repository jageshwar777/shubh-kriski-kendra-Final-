name: Build APK

on:
  push:
    branches: [ main ]
  workflow_dispatch:

jobs:
  build:
    runs-on: ubuntu-latest
    
    env:
      FORCE_JAVASCRIPT_ACTIONS_TO_NODE24: true
    
    steps:
      - uses: actions/checkout@v4
      
      - uses: subosito/flutter-action@v2
        with:
          flutter-version: '3.22.0'
          channel: 'stable'
      
      - name: Install dependencies
        run: |
          flutter clean
          flutter pub get
      
      - name: Build APK
        run: flutter build apk --release
      
      - name: Find and Copy APK
        run: |
          find . -name "*.apk" -type f
          mkdir -p build/app/outputs/flutter-apk/
          cp android/app/build/outputs/apk/release/*.apk build/app/outputs/flutter-apk/app-release.apk || true
          cp android/app/build/outputs/apk/release/*.apk build/app/outputs/flutter-apk/ || true
          cp build/app/outputs/apk/release/*.apk build/app/outputs/flutter-apk/ || true
          ls -la build/app/outputs/flutter-apk/
      
      - name: Upload APK
        uses: actions/upload-artifact@v4
        with:
          name: app-release
          path: build/app/outputs/flutter-apk/app-release.apk
